{
  "name": "sophia-awakening",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "build:visual": "tsc --noEmit && vite build --config vite.visual.config.ts",
    "preview": "vite preview --host 127.0.0.1",
    "sim": "tsc -p tsconfig.sim.json && node scripts/sim.cjs",
    "sim:fast": "node scripts/sim.cjs",
    "loopcheck": "tsc -p tsconfig.sim.json && node scripts/loop-check.cjs",
    "loopcheck:fast": "node scripts/loop-check.cjs",
    "simbuild": "tsc -p tsconfig.sim.json"
  },
  "dependencies": {
    "@types/three": "^0.185.0",
    "break_infinity.js": "^2.2.0",
    "gsap": "^3.13.0",
    "pixi.js": "^8.10.0",
    "three": "^0.185.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^8.0.16"
  }
}
